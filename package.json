{
  "name": "translation-pwa-app",
  "private": true,
  "version": "1.0.0",
  "repository": "git@github.com:KlessitonRodrigues/translation-pwa.git",
  "author": "klessiton <klessitom@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "dependencies": {
    "turbo": "^2.8.13"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": {
    "packages": [
      "applications/*",
      "packages/*",
      "services/*"
    ],
    "nohoist": [
      "**/@aws-sdk/**",
      "**/aws-cdk",
      "**/aws-cdk/**",
      "**/aws-cdk-lib",
      "**/aws-cdk-lib/**",
      "**/constructs",
      "**/constructs/**"
    ]
  }
}
